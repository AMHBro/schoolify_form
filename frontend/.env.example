# مشروع Supabase: الإعدادات > API — Project URL و anon public key
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# (اختياري) روابط قديمة: /teacher?aid=UUID&tv=TOKEN دون تسجيل دخول
# VITE_SUPABASE_ASSIGNMENT_ID=
# VITE_SUPABASE_TEACHER_TOKEN=

# للتطوير فقط: إظهار زر/رابط تجربة طالب (DEMO2024) على الواجهة
# VITE_ALLOW_STUDENT_DEMO=true

# لوحة /system في الوضع المحلي: مفتاح فك القفل (الافتراضي schoolify-dev-admin)
# VITE_SYSTEM_ADMIN_MOCK_KEY=my-local-secret

# على Supabase: نفّذ supabase/migrations/20260408240000_system_admin_dashboard.sql
# ثم غيّر المفتاح: UPDATE public.system_admin_config SET secret_key = '...';
